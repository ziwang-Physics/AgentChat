# AgentChat — 环境配置文件
# 复制为 .env 并根据你的环境修改:
#   cp .env.example .env
#
# 脚本会自动加载项目根目录的 .env 文件，无需手动 source。

# 本文件自 v16 起由 Node 侧 (skills/lib/cdp.js) 直接安全加载 — 不再依赖
# shell wrapper source。查找顺序: AGENTCHAT_ENV_FILE → <仓库根>/.env → <CWD>/.env。
# 已存在的进程环境变量优先于本文件。值永远按字面字符串处理，绝不执行。

# Chrome/Chromium 二进制路径 (REQUIRED — 必须设置为系统 Chrome，不能用 Playwright 自带)
# Linux 常见路径: /usr/bin/google-chrome-stable, /usr/bin/chromium
# macOS 常见路径: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Windows 常见路径: C:\Program Files\Google\Chrome\Application\chrome.exe
# 未设置时 v16 内嵌启动器按上述标准路径自动探测（含 Edge 兜底）。
CHROMIUM_PATH=

# CDP 调试端口
CDP_PORT=9222

# CDP 主机 (默认 127.0.0.1)。仅在 Chrome 与 skill 不在同一网络命名空间时设置：
# 典型场景 = WSL2 里跑 skill、Chrome 跑在 Windows 宿主 —— WSL2 内的
# 127.0.0.1 指向 VM 自身，需改为 Windows 宿主 IP（cat /etc/resolv.conf 的
# nameserver 行），且 Windows 侧 Chrome 需加 --remote-debugging-address=0.0.0.0
# （仅限可信网络！该端口等于整个已登录 profile 的完全控制权）。
# CDP_HOST=127.0.0.1

# HTTP/SOCKS5 代理地址 (中国大陆用户必须配置)
PROXY_SERVER=http://127.0.0.1:7897

# Chrome 持久化 Profile 目录 (保存 Google 登录状态)
# Windows 用户: `~` 由 start-chrome.ps1 (v15+) 展开为 %USERPROFILE%；
# 旧版脚本会把字面 `~` 传给 Chrome 导致登录态写入错误目录。
# 建议 Windows 上直接写绝对路径，如 C:\Users\<you>\.chrome-debug-profile
CHROME_PROFILE=~/.chrome-debug-profile

# Gemini URL
GEMINI_URL=https://gemini.google.com/u/0/app

# 日志文件
LOG_FILE=/tmp/chrome-debug.log

# 无头模式 (默认: false, 即 GUI 可见窗口)
# 设置为 "1" / "true" / "yes" 启用 headless
HEADLESS=false
