# AgentChat — 环境配置文件
# 复制为 .env 并根据你的环境修改:
#   cp .env.example .env
#
# 脚本会自动加载项目根目录的 .env 文件，无需手动 source。

# Chrome/Chromium 二进制路径 (REQUIRED — 必须设置为系统 Chrome，不能用 Playwright 自带)
# Linux 常见路径: /usr/bin/google-chrome-stable, /usr/bin/chromium
# macOS 常见路径: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROMIUM_PATH=

# CDP 调试端口
CDP_PORT=9222

# HTTP/SOCKS5 代理地址 (中国大陆用户必须配置)
PROXY_SERVER=http://127.0.0.1:7897

# Chrome 持久化 Profile 目录 (保存 Google 登录状态)
CHROME_PROFILE=~/.chrome-debug-profile

# Gemini URL
GEMINI_URL=https://gemini.google.com/u/0/app

# 日志文件
LOG_FILE=/tmp/chrome-debug.log

# 无头模式 (默认: false, 即 GUI 可见窗口)
# 设置为 "1" / "true" / "yes" 启用 headless
HEADLESS=false
