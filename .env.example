# AgentChat — Environment Configuration
# ====================================
# Copy to .env and adjust for your environment:
#   Linux/macOS:  cp .env.example .env
#   Windows:      copy .env.example .env
#
# Startup scripts (start-chrome.sh / start-chrome.ps1) auto-load .env.

# ── Browser ──────────────────────────────────────────────────────────────
# Path to Chrome/Chromium binary. Leave empty to auto-detect.
#   Linux:   /usr/bin/google-chrome-stable
#   macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
CHROMIUM_PATH=

# CDP debug port (Chrome DevTools Protocol)
CDP_PORT=9222

# ── Network ──────────────────────────────────────────────────────────────
# HTTP/SOCKS5 proxy address. Required for users in mainland China.
# Leave empty if you can access Google directly (VPN/TUN mode).
#   Clash Verge: http://127.0.0.1:7897
#   v2rayN:      http://127.0.0.1:10809
PROXY_SERVER=http://127.0.0.1:7897

# ── Profile ──────────────────────────────────────────────────────────────
# Chrome persistent profile directory (stores Google login state).
#   Linux/macOS: ~/.chrome-debug-profile
#   Windows:     %USERPROFILE%\.chrome-debug-profile
CHROME_PROFILE=~/.chrome-debug-profile

# Gemini target URL
GEMINI_URL=https://gemini.google.com/u/0/app

# ── Logging ──────────────────────────────────────────────────────────────
#   Linux/macOS: /tmp/chrome-debug.log
#   Windows:     %TEMP%\chrome-debug.log
LOG_FILE=/tmp/chrome-debug.log

# ── China mirror (optional) ──────────────────────────────────────────────
# Set to 1 to use Tsinghua/Aliyun mirrors for faster pip/npm installs.
USE_CHINA_MIRROR=0
