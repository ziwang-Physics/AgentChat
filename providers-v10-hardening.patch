+        info.forEach((b, i) => {
+            log(`  [${i}] <${b.tag}> id="${b.id}" len=${b.len} class="${b.classes}" text="${b.preview}"`);
+        });
+    } catch (e) {
+        log(`DIAG: response dump failed: ${e.message}`);
+    }
